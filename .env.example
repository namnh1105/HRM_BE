# Worksphere Environment Configuration
# Copy this file to .env and fill in the actual values

# Application Configuration
APP_PORT=8080
SPRING_PROFILES_ACTIVE=production

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-must-be-at-least-32-characters-long
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# Database Configuration (PostgreSQL)
POSTGRES_DB=worksphere
POSTGRES_USER=worksphere
POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Google OAuth2 Configuration
GOOGLE_OAUTH2_CLIENT_ID=your-google-oauth2-client-id
GOOGLE_OAUTH2_CLIENT_SECRET=your-google-oauth2-client-secret
GOOGLE_OAUTH2_REDIRECT_URI=https://your-domain.com/login/oauth2/code/google

# Server Configuration
SERVER_PORT=8080
FRONTEND_URL=https://your-frontend-domain.com
OAUTH_SUCCESS_REDIRECT_PATH=/oauth/callback

# JPA/Hibernate Configuration
DDL_AUTO=update
SHOW_SQL=false
FORMAT_SQL=false

# Development specific overrides (uncomment for development)
# SPRING_PROFILES_ACTIVE=development
# GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google
# FRONTEND_URL=http://localhost:3000
# SHOW_SQL=true
# FORMAT_SQL=true
